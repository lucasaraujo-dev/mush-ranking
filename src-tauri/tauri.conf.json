{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Mush Ranking",
  "version": "0.1.0",
  "identifier": "br.com.mushranking.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mush Ranking",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "headerImage": "installer-assets/nsis-header.bmp",
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "languages": [
          "PortugueseBR",
          "English"
        ],
        "sidebarImage": "installer-assets/nsis-sidebar.bmp"
      },
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
